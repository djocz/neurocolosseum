# ════════════════════════════════════════
# NeuroColosseum — Environment Template
# Two models enter. One argument wins.
#
# Only fill in keys for providers you use.
# All keys are optional at startup.
# ════════════════════════════════════════

# ── Major Cloud Providers ─────────────────
# Only add keys for providers you actually use

ANTHROPIC_API_KEY=        # console.anthropic.com
OPENAI_API_KEY=           # platform.openai.com
GROQ_API_KEY=             # console.groq.com (free tier)
GOOGLE_API_KEY=           # aistudio.google.com
MISTRAL_API_KEY=          # console.mistral.ai
COHERE_API_KEY=           # dashboard.cohere.com
FIREWORKS_API_KEY=        # fireworks.ai
TOGETHER_API_KEY=         # api.together.xyz
HUGGINGFACEHUB_API_TOKEN= # huggingface.co/settings/tokens
XAI_API_KEY=              # x.ai (Grok)
PPLX_API_KEY=             # perplexity.ai

# ── Cloud Platform Providers ──────────────
# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
OPENAI_API_VERSION=2025-03-01-preview

# AWS Bedrock — uses AWS CLI credentials
# Run: aws configure
# No API key needed here

# Google Vertex AI — uses service account
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ── Local Providers (no key needed) ───────
# Ollama — install from ollama.com then:
#   ollama pull llama3
#   ollama pull mistral
#   ollama pull gemma2
# No API key needed

# ── Model Configuration ───────────────────
# Change these to use any provider above

LLM_DEBATER_A=anthropic/claude-sonnet-4-6
LLM_DEBATER_B=groq/llama-3.3-70b-versatile
LLM_JUDGE=openai/gpt-4o

# ── Free debate examples ──────────────────
# Groq only (free tier):
# LLM_DEBATER_A=groq/llama-3.3-70b-versatile
# LLM_DEBATER_B=groq/llama-3.3-70b-versatile
# LLM_JUDGE=groq/llama-3.3-70b-versatile

# Ollama only (completely free, local):
# LLM_DEBATER_A=ollama/llama3
# LLM_DEBATER_B=ollama/mistral
# LLM_JUDGE=ollama/llama3

# Google Gemini:
# LLM_DEBATER_A=google_genai/gemini-2.5-flash
# LLM_DEBATER_B=google_genai/gemini-2.5-flash
# LLM_JUDGE=google_genai/gemini-2.5-flash

# ── Debate Settings ───────────────────────
DEBATE_TOPIC=AI will do more harm than good
DEBATER_AWARENESS=criteria
CROSS_EXAM_QUESTIONS=3

# ── Scoring Settings ──────────────────────
MAX_ARGUMENT_WORDS=400
MAX_QUESTION_WORDS=80
TIEBREAK_THRESHOLD=0
LENGTH_PENALTY=true

# ── Output Settings ───────────────────────
SAVE_TRANSCRIPT=true
TRANSCRIPT_DIR=outputs

# ── Monitoring (optional) ─────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=neurocolosseum
LANGSMITH_TRACING=false